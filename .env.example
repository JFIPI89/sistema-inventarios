# =============================================================================
# DESARROLLO LOCAL con Neon
# =============================================================================
# Usa la URL DIRECT (sin "-pooler") como DATABASE_URL en local.
# El pooler cierra conexiones inactivas y genera errores "Connection Closed"
# con `npm run dev` corriendo mucho rato.
#
# DIRECT_URL se usa igual para migraciones: npm run db:push / db:seed

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# =============================================================================
# PRODUCCIÓN (Vercel) — no copies esto a .env local
# =============================================================================
# En Vercel usa la URL POOLED (-pooler) como DATABASE_URL:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

AUTH_SECRET="change-this-to-a-random-secret-at-least-32-characters"
# Opcional — ignorado: la app siempre formatea en MXN (es-MX).
# CURRENCY_CODE="MXN"

# IP Wi-Fi de tu PC (para demo en celular en la misma red)
LAN_IP=192.168.1.139
